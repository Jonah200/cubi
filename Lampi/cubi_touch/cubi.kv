#:kivy 1.9

<StartScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10

        Label:
            text: app.scramble
            text_size: self.width, None
            size_hint_y: None
            height: self.texture_size[1]
            halign: 'center'

        Button: 
            text: "Generate New Scramble"
            size_hint_y: 0.2
            on_press: root.rescramble()

        Button:
            text: "View Scramble"
            size_hint_y: 0.2
            on_press: root.go_to_vis()
            
        Button:
            text: "Start Inspection"
            size_hint_y: 0.3
            on_press: root.go_to_inspection()

<VisScreen>:
    BoxLayout:
        orientation: "vertical"
        Label:
            text: app.scramble
            text_size: self.width, None
            halign: "center"
            size_hint_y: 0.2
        Button:
            size_hint_y: 0.15
            text: "Generate New Scramble"
            on_press: root.rescramble()
        Button:
            size_hint_y: 0.15
            text: "Start Inspection"
            on_press: root.go_to_inspection()
        GridLayout:
            size_hint_y: 0.5
            id: vis_grid
            spacing: [4]
            cols: 4
            rows: 3

<InspectionScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20
        Label:
            text: str(root.time_left)
            font_size: 48
        Label:
            text: root.ready_set_go
            halign: 'center'
            font_size: 40


<SolveScreen>:
    BoxLayout:
        orientation: 'vertical'
        Label:
            text: "SOLVE!"
            halign: 'center'
            font_size: 40
        Label:
            text: root.time_text
            font_size: 48
